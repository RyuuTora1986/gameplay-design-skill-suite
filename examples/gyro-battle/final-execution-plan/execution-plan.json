      ],
      "canonical_ids": [
        "SYS-01",
        "FML-01",
        "CFG-01"
      ],
      "goal": "Turn the first playable loop into an explicit verification gate.",
      "deliverables": [
        "QA checklist entry",
        "loop verification scenario",
        "failure-state verification scenario"
